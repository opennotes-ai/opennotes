{
  "name": "@opennotes/ui",
  "version": "0.0.1",
  "description": "Shared Solid UI components, utilities, and palettes for Open Notes surfaces",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./palettes": {
      "types": "./dist/palettes/index.d.ts",
      "import": "./dist/palettes/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@opennotes/tokens": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0",
    "@kobalte/core": "^0.13.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/testing-library": "^0.8.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsdom": "^29.0.1",
    "solid-js": "^1.9.5",
    "tailwind-merge": "^3.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "opennotes",
    "design-system",
    "ui",
    "solid"
  ],
  "license": "MIT"
}
