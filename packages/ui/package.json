{
  "name": "@opennotes/ui",
  "version": "0.0.1",
  "description": "Shared Solid UI components, utilities, and palettes for Open Notes surfaces",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "solid": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./components": {
      "solid": "./src/components/index.ts",
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts"
    },
    "./components/*": {
      "solid": "./src/components/*.tsx",
      "types": "./src/components/*.tsx",
      "import": "./src/components/*.tsx"
    },
    "./utils": {
      "solid": "./src/utils/index.ts",
      "types": "./src/utils/index.ts",
      "import": "./src/utils/index.ts"
    },
    "./utils/*": {
      "solid": "./src/utils/*.ts",
      "types": "./src/utils/*.ts",
      "import": "./src/utils/*.ts"
    },
    "./palettes": {
      "solid": "./src/palettes/index.ts",
      "types": "./src/palettes/index.ts",
      "import": "./src/palettes/index.ts"
    },
    "./palettes/*": {
      "solid": "./src/palettes/*.ts",
      "types": "./src/palettes/*.ts",
      "import": "./src/palettes/*.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@opennotes/tokens": "workspace:*",
    "embla-carousel-autoplay": "9.0.0-rc02",
    "embla-carousel-solid": "9.0.0-rc02",
    "embla-carousel-ssr": "9.0.0-rc02"
  },
  "peerDependencies": {
    "@kobalte/core": "^0.13.0",
    "@solidjs/router": "^0.15.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "echarts": "^6.0.0",
    "solid-js": "^1.9.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.15.3",
    "@solidjs/testing-library": "^0.8.10",
    "@types/node": "^20.19.39",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "jsdom": "^29.0.1",
    "solid-js": "^1.9.5",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "opennotes",
    "design-system",
    "ui",
    "solid"
  ],
  "license": "MIT"
}
