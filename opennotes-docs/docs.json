              "integration-guide/onboarding/mint-api-keys",
              "integration-guide/onboarding/configure-tiers"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "integration-guide/concepts/authentication",
              "integration-guide/concepts/adapter-headers",
              "integration-guide/concepts/scopes"
            ]
          },
          {
            "group": "Adapter choreography",
            "pages": [
              "integration-guide/choreography/overview",
              "integration-guide/choreography/content-lifecycle",
              "integration-guide/choreography/review-lifecycle",
              "integration-guide/choreography/webhooks-and-errors"
            ]
          }
        ]
      },
      {
        "tab": "Existing Integrations",
        "groups": [
          {
            "group": "Overview",
            "pages": ["existing-integrations/overview"]
          },
          {
            "group": "Discourse plugin",
            "pages": [
              "existing-integrations/discourse/overview",
              "existing-integrations/discourse/install",
              "existing-integrations/discourse/configure",
              "existing-integrations/discourse/upgrade",
              "existing-integrations/discourse/troubleshoot",
              "existing-integrations/discourse/user-guide"
            ]
          }
        ]
      },
