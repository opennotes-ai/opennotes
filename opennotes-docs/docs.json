        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication",
              "api-reference/conventions"
            ]
          }
        ],
        "openapi": {
          "source": "../opennotes-server/openapi-public.json",
          "directory": "api-reference/endpoints"
        }
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Platform",
        "href": "https://platform.opennotes.ai"
      },
      {
        "label": "GitHub",
