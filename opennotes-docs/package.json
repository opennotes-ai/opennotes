{
  "name": "@opennotes/docs",
  "version": "0.0.0",
  "private": true,
  "description": "OpenNotes documentation site (Mintlify)",
  "scripts": {
    "vendor:tokens": "mkdir -p styles/tokens && cp ../packages/tokens/src/*.css styles/tokens/",
    "prevalidate": "pnpm run vendor:tokens",
    "dev": "pnpm run vendor:tokens && mint dev",
    "validate": "mint validate",
    "broken-links": "pnpm run vendor:tokens && mint broken-links"
  }
}
