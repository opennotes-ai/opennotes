  "components": {
    "schemas": {
      "AnalyzeRequest": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url",
            "description": "HTTP(S) URL of the page to analyze"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "AnalyzeRequest"
      },
      "AnalyzeResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "format": "uuid",
            "title": "Job Id"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "cached": {
            "type": "boolean",
            "title": "Cached"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status",
          "cached"
        ],
        "title": "AnalyzeResponse",
        "description": "202 handoff payload.\n\nThe response shape is intentionally minimal: the client uses `job_id` to\npoll `GET /api/analyze/{job_id}` (TASK-1473.14) for progressive fill.\n`cached=true` signals that the pipeline was skipped because a fresh\n`vibecheck_analyses` row was already available \u2014 the polled job will\nreach `status=done` immediately."
      },
      "ClaimsReport": {
        "properties": {
          "deduped_claims": {
            "items": {
              "$ref": "#/components/schemas/DedupedClaim"
            },
            "type": "array",
            "title": "Deduped Claims"
          },
          "total_claims": {
            "type": "integer",
            "title": "Total Claims"
          },
          "total_unique": {
            "type": "integer",
            "title": "Total Unique"
          }
        },
        "type": "object",
        "required": [
          "deduped_claims",
          "total_claims",
          "total_unique"
        ],
        "title": "ClaimsReport",
        "description": "Output of `dedupe_claims` \u2014 prevalence stats for the Facts sidebar."
      },
      "DedupedClaim": {
        "properties": {
          "canonical_text": {
            "type": "string",
            "title": "Canonical Text"
          },
          "occurrence_count": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Occurrence Count"
          },
          "author_count": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Author Count"
          },
          "utterance_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Utterance Ids"
          },
          "representative_authors": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Representative Authors"
          }
        },
        "type": "object",
        "required": [
          "canonical_text",
          "occurrence_count",
          "author_count",
          "utterance_ids",
          "representative_authors"
        ],
        "title": "DedupedClaim",
        "description": "A cluster of semantically-equivalent claims across utterances."
      },
      "ErrorCode": {
        "type": "string",
        "enum": [
          "invalid_url",
          "unsupported_site",
          "upstream_error",
          "extraction_failed",
          "timeout",
          "rate_limited",
          "internal"
        ],
        "title": "ErrorCode",
        "description": "Stable error codes the frontend branches on for inline copy + retry UX."
      },
      "FactCheckMatch": {
        "properties": {
          "claim_text": {
            "type": "string",
            "title": "Claim Text"
          },
          "publisher": {
            "type": "string",
            "title": "Publisher"
          },
          "review_title": {
            "type": "string",
            "title": "Review Title"
          },
          "review_url": {
            "type": "string",
            "title": "Review Url"
          },
          "textual_rating": {
            "type": "string",
            "title": "Textual Rating"
          },
          "review_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Review Date"
          }
        },
        "type": "object",
        "required": [
          "claim_text",
          "publisher",
          "review_title",
          "review_url",
          "textual_rating"
        ],
        "title": "FactCheckMatch",
        "description": "A single fact-check article surfaced by the Google Fact Check Tools API.\n\nOne claim (as extracted+deduped from an utterance) can map to multiple\n`FactCheckMatch` rows \u2014 each corresponding to one `claimReview` entry\nreturned by the API. We keep the original claim text alongside the\nreviewer-supplied metadata so the UI can show provenance clearly."
      },
      "FactsClaimsSection": {
        "properties": {
          "claims_report": {
            "$ref": "#/components/schemas/ClaimsReport"
          },
          "known_misinformation": {
            "items": {
              "$ref": "#/components/schemas/FactCheckMatch"
            },
            "type": "array",
            "title": "Known Misinformation"
          }
        },
        "type": "object",
        "required": [
          "claims_report"
        ],
        "title": "FactsClaimsSection",
        "description": "Deduped verifiable claims and any matching published fact-checks."
      },
      "FlashpointMatch": {
        "properties": {
          "scan_type": {
            "type": "string",
            "const": "conversation_flashpoint",
            "title": "Scan Type",
            "default": "conversation_flashpoint"
          },
          "utterance_id": {
            "type": "string",
            "title": "Utterance Id",
            "description": "Platform-agnostic identifier of the scored utterance"
          },
          "derailment_score": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Derailment Score",
            "description": "Derailment risk score (0-100)"
          },
          "risk_level": {
            "$ref": "#/components/schemas/RiskLevel",
            "description": "Categorical risk assessment level"
          },
          "reasoning": {
            "type": "string",
            "title": "Reasoning",
            "description": "Explanation of detected escalation signals"
          },
          "context_messages": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Context Messages",
            "description": "Number of context messages analyzed"
          }
        },
        "type": "object",
        "required": [
          "utterance_id",
          "derailment_score",
          "risk_level",
          "reasoning",
          "context_messages"
        ],
        "title": "FlashpointMatch",
        "description": "Match result from flashpoint detection for a single utterance.\n\nPort of ``ConversationFlashpointMatch`` from opennotes-server, adapted\nfor the vibecheck utterance model: ``utterance_id`` replaces Discord\n``message_id``; other fields are unchanged."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HarmfulContentMatch": {
        "properties": {
          "utterance_id": {
            "type": "string",
            "title": "Utterance Id"
          },
          "max_score": {
            "type": "number",
            "title": "Max Score"
          },
          "categories": {
            "additionalProperties": {
              "type": "boolean"
            },
            "type": "object",
            "title": "Categories"
          },
          "scores": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Scores"
          },
          "flagged_categories": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Flagged Categories"
          }
        },
        "type": "object",
        "required": [
          "utterance_id",
          "max_score",
          "categories",
          "scores"
        ],
        "title": "HarmfulContentMatch",
        "description": "A single flagged utterance from the OpenAI moderation API."
      },
      "JobState": {
        "properties": {
          "job_id": {
            "type": "string",
            "format": "uuid",
            "title": "Job Id"
          },
          "url": {
            "type": "string",
            "title": "Url"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "attempt_id": {
            "type": "string",
            "format": "uuid",
            "title": "Attempt Id"
          },
          "error_code": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ErrorCode"
              },
              {
                "type": "null"
              }
            ]
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          },
          "error_host": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Host",
            "description": "When ErrorCode.UNSUPPORTED_SITE is returned, the host that triggered the rejection."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "sections": {
            "additionalProperties": {
              "$ref": "#/components/schemas/SectionSlot"
            },
            "propertyNames": {
              "$ref": "#/components/schemas/SectionSlug"
            },
            "type": "object",
            "title": "Sections"
          },
          "sidebar_payload": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SidebarPayload"
              },
              {
                "type": "null"
              }
            ]
          },
          "cached": {
            "type": "boolean",
            "title": "Cached",
            "default": false
          },
          "next_poll_ms": {
            "type": "integer",
            "title": "Next Poll Ms",
            "description": "Server-suggested delay until the client should re-poll. Clients use this to implement adaptive cadence (typically 500ms early, 1500ms+ near completion).",
            "default": 1500
          },
          "page_title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Page Title",
            "description": "Extracted page title, sourced from vibecheck_job_utterances. Null until the extractor runs."
          },
          "page_kind": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PageKind"
              },
              {
                "type": "null"
              }
            ],
            "description": "Extracted page shape, sourced from vibecheck_job_utterances. Null until the extractor runs."
          },
          "utterance_count": {
            "type": "integer",
            "title": "Utterance Count",
            "description": "Number of utterances extracted for this job. 0 until the extractor writes any rows.",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "url",
          "status",
          "attempt_id",
          "created_at",
          "updated_at"
        ],
        "title": "JobState",
        "description": "GET /api/analyze/{job_id} response shape (wired in TASK-1473.14).\n\nCombines job-level lifecycle (status/error_code/error_message), per-slot\nprogress (sections), the assembled sidebar (sidebar_payload, populated\nonce all slots finish), and an adaptive polling hint (next_poll_ms) so\nclients can back off as the job completes."
      },
      "JobStatus": {
        "type": "string",
        "enum": [
          "pending",
          "extracting",
          "analyzing",
          "done",
          "failed"
        ],
        "title": "JobStatus",
        "description": "Lifecycle of a vibecheck job from POST to terminal state."
      },
      "OpinionsReport": {
        "properties": {
          "sentiment_stats": {
            "$ref": "#/components/schemas/SentimentStatsReport"
          },
          "subjective_claims": {
            "items": {
              "$ref": "#/components/schemas/SubjectiveClaim"
            },
            "type": "array",
            "title": "Subjective Claims"
          }
        },
        "type": "object",
        "required": [
          "sentiment_stats",
          "subjective_claims"
        ],
        "title": "OpinionsReport"
      },
      "OpinionsSection": {
        "properties": {
          "opinions_report": {
            "$ref": "#/components/schemas/OpinionsReport"
          }
        },
        "type": "object",
        "required": [
          "opinions_report"
        ],
        "title": "OpinionsSection",
        "description": "Sentiment distribution and extracted subjective claims."
      },
      "PageKind": {
        "type": "string",
        "enum": [
          "blog_post",
          "forum_thread",
          "hierarchical_thread",
          "blog_index",
          "article",
          "other"
        ],
        "title": "PageKind",
        "description": "Shape of the source page the extractor handled.\n\nThe extractor in TASK-1473.10 picks one of these; downstream rendering\nand analysis logic branches on the value (e.g., hierarchical_thread\nenables tree-aware flashpoint context)."
      },
      "RetryResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "format": "uuid",
            "title": "Job Id"
          },
          "slug": {
            "$ref": "#/components/schemas/SectionSlug"
          },
          "slot_attempt_id": {
            "type": "string",
            "format": "uuid",
            "title": "Slot Attempt Id"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "slug",
          "slot_attempt_id"
        ],
        "title": "RetryResponse",
        "description": "202 handoff payload for a successful retry CAS."
      },
      "RiskLevel": {
        "type": "string",
        "enum": [
          "Low Risk",
          "Guarded",
          "Heated",
          "Hostile",
          "Dangerous"
        ],
        "title": "RiskLevel",
        "description": "Categorical risk level for conversation flashpoint detection."
      },
      "RunJobBody": {
        "properties": {
          "job_id": {
            "type": "string",
            "format": "uuid",
            "title": "Job Id"
          },
          "expected_attempt_id": {
            "type": "string",
            "format": "uuid",
            "title": "Expected Attempt Id"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "expected_attempt_id"
        ],
        "title": "RunJobBody",
        "description": "Cloud Tasks request payload for the run endpoint."
      },
      "RunSectionBody": {
        "properties": {
          "job_id": {
            "type": "string",
            "format": "uuid",
            "title": "Job Id"
          },
          "slug": {
            "$ref": "#/components/schemas/SectionSlug"
          },
          "expected_slot_attempt_id": {
            "type": "string",
            "format": "uuid",
            "title": "Expected Slot Attempt Id"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "slug",
          "expected_slot_attempt_id"
        ],
        "title": "RunSectionBody",
        "description": "Cloud Tasks request payload for the per-section retry endpoint."
      },
      "SCDReport": {
        "properties": {
          "narrative": {
            "type": "string",
            "title": "Narrative",
            "description": "Conversational-register narrative (~80-150 words) describing how the conversation unfolds: turn-taking dynamics, escalation or de-escalation, shifts in stance, and persuasive moves. Prose voice \u2014 does not restate specific topics, claims, or quotes.",
            "default": ""
          },
          "speaker_arcs": {
            "items": {
              "$ref": "#/components/schemas/SpeakerArc"
            },
            "type": "array",
            "title": "Speaker Arcs",
            "description": "Per-speaker arcs across the conversation, ordered for timeline visualization. Each arc carries the speaker label, a short note on their evolution, and an optional utterance index range so the frontend can align the arc with the rendered transcript."
          },
          "summary": {
            "type": "string",
            "title": "Summary",
            "description": "Legacy: overall conversational-dynamics narrative (<= ~80 words). Captures sentiment shifts, intentions, and persuasive strategies without restating specific topics or claims. Preserved for back-compat with existing consumers; new code should read `narrative` instead."
          },
          "tone_labels": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tone Labels",
            "description": "Legacy: short tone descriptors for the conversation as a whole (e.g. 'combative', 'collaborative', 'dismissive', 'civil'). Preserved for back-compat."
          },
          "per_speaker_notes": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Per Speaker Notes",
            "description": "Legacy: map of speaker label -> 1-2 sentence observation about that speaker's tone, intent, or conversational strategy. Preserved for back-compat; new code should read `speaker_arcs` for timeline-viz-ready per-speaker information."
          },
          "insufficient_conversation": {
            "type": "boolean",
            "title": "Insufficient Conversation",
            "description": "True when the input lacks a real multi-speaker exchange (e.g. a blog post with no comments). When true, callers should treat `summary` as a fixed placeholder and ignore `tone_labels` / `per_speaker_notes` / `speaker_arcs`.",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "summary"
        ],
        "title": "SCDReport",
        "description": "Structured output of `analyze_scd`.\n\nMirrors the structural intent of Cornell ConvoKit's SCD trajectory summary,\nbut in a conversational register: a free-form `narrative` describing how\nthe conversation unfolds, and a structured `speaker_arcs` list ready for\ntimeline visualization. Legacy fields (`summary`, `tone_labels`,\n`per_speaker_notes`, `insufficient_conversation`) are retained so existing\nconsumers continue to work while orchestrator slot wiring is migrated.\nFor inputs that lack a real multi-speaker conversation, the model is\nbypassed and `insufficient_conversation=True` is set."
      },
      "SafetySection": {
        "properties": {
          "harmful_content_matches": {
            "items": {
              "$ref": "#/components/schemas/HarmfulContentMatch"
            },
            "type": "array",
            "title": "Harmful Content Matches"
          }
        },
        "type": "object",
        "title": "SafetySection",
        "description": "Harmful-content matches surfaced by OpenAI moderation."
      },
      "SectionSlot": {
        "properties": {
          "state": {
            "$ref": "#/components/schemas/SectionState"
          },
          "attempt_id": {
            "type": "string",
            "format": "uuid",
            "title": "Attempt Id"
          },
          "data": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Data"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "started_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "finished_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finished At"
          }
        },
        "type": "object",
        "required": [
          "state",
          "attempt_id"
        ],
        "title": "SectionSlot",
        "description": "One sidebar slot's state inside a JobState.\n\n`attempt_id` is regenerated on each retry; Cloud Tasks redeliveries that\ncarry a stale attempt_id are rejected by the worker. `data` holds the\nsection-specific payload once `state == DONE` (shape varies by slug)."
      },
      "SectionSlug": {
        "type": "string",
        "enum": [
          "safety__moderation",
          "tone_dynamics__flashpoint",
          "tone_dynamics__scd",
          "facts_claims__dedup",
          "facts_claims__known_misinfo",
          "opinions_sentiments__sentiment",
          "opinions_sentiments__subjective"
        ],
        "title": "SectionSlug",
        "description": "The seven sidebar slots the async pipeline fills independently."
      },
      "SectionState": {
        "type": "string",
        "enum": [
          "pending",
          "running",
          "done",
          "failed"
        ],
        "title": "SectionState",
        "description": "Lifecycle of a single sidebar slot during a job."
      },
      "SentimentScore": {
        "properties": {
          "utterance_id": {
            "type": "string",
            "title": "Utterance Id"
          },
          "label": {
            "type": "string",
            "enum": [
              "positive",
              "negative",
              "neutral"
            ],
            "title": "Label"
          },
          "valence": {
            "type": "number",
            "maximum": 1.0,
            "minimum": -1.0,
            "title": "Valence"
          }
        },
        "type": "object",
        "required": [
          "utterance_id",
          "label",
          "valence"
        ],
        "title": "SentimentScore"
      },
      "SentimentStatsReport": {
        "properties": {
          "per_utterance": {
            "items": {
              "$ref": "#/components/schemas/SentimentScore"
            },
            "type": "array",
            "title": "Per Utterance"
          },
          "positive_pct": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Positive Pct"
          },
          "negative_pct": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Negative Pct"
          },
          "neutral_pct": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Neutral Pct"
          },
          "mean_valence": {
            "type": "number",
            "maximum": 1.0,
            "minimum": -1.0,
            "title": "Mean Valence"
          }
        },
        "type": "object",
        "required": [
          "per_utterance",
          "positive_pct",
          "negative_pct",
          "neutral_pct",
          "mean_valence"
        ],
        "title": "SentimentStatsReport"
      },
      "SidebarPayload": {
        "properties": {
          "source_url": {
            "type": "string",
            "title": "Source Url"
          },
          "page_title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Page Title"
          },
          "page_kind": {
            "$ref": "#/components/schemas/PageKind",
            "default": "other"
          },
          "scraped_at": {
            "type": "string",
            "format": "date-time",
            "title": "Scraped At"
          },
          "cached": {
            "type": "boolean",
            "title": "Cached",
            "default": false
          },
          "cached_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cached At"
          },
          "safety": {
            "$ref": "#/components/schemas/SafetySection"
          },
          "tone_dynamics": {
            "$ref": "#/components/schemas/ToneDynamicsSection"
          },
          "facts_claims": {
            "$ref": "#/components/schemas/FactsClaimsSection"
          },
          "opinions_sentiments": {
            "$ref": "#/components/schemas/OpinionsSection"
          }
        },
        "type": "object",
        "required": [
          "source_url",
          "scraped_at",
          "safety",
          "tone_dynamics",
          "facts_claims",
          "opinions_sentiments"
        ],
        "title": "SidebarPayload",
        "description": "Top-level response for `POST /api/analyze`.\n\nAggregates all four sidebar sections plus identity/metadata fields the\nfrontend needs to render the result. `cached=True` indicates the payload\nwas served from the Supabase cache (72h TTL) instead of a freshly run\npipeline."
      },
      "SpeakerArc": {
        "properties": {
          "speaker": {
            "type": "string",
            "title": "Speaker",
            "description": "Speaker label as it appears in the formatted transcript (e.g. 'alice', 'Speaker1')."
          },
          "note": {
            "type": "string",
            "title": "Note",
            "description": "1-2 sentence observation about this speaker's arc: how their tone, intent, or stance evolves across the conversation."
          },
          "utterance_id_range": {
            "anyOf": [
              {
                "items": {
                  "type": "integer"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Utterance Id Range",
            "description": "Inclusive [start, end] 1-indexed utterance index range that this arc covers, for timeline-viz alignment. Exactly two integers with start <= end and start >= 1. `None` when the LLM cannot localize the arc to a contiguous span. Modeled as a list (not a tuple) so the generated OpenAPI schema produces a plain integer array rather than a fixed-length prefixItems tuple, which openapi-fetch widens to `number[]` and would otherwise cause a TS2719 mismatch with the named JobState response type."
          }
        },
        "type": "object",
        "required": [
          "speaker",
          "note"
        ],
        "title": "SpeakerArc",
        "description": "Per-speaker arc within a conversation, intended for timeline visualization.\n\nEach arc localizes one speaker's contribution to the conversational shape:\na short prose `note` paired with an optional `utterance_id_range` so the\nfrontend can map the arc back onto the rendered transcript timeline. The\nrange is `None` when the LLM cannot confidently localize the arc to a\ncontiguous span (e.g. interleaved or sparse contributions)."
      },
      "SubjectiveClaim": {
        "properties": {
          "claim_text": {
            "type": "string",
            "title": "Claim Text"
          },
          "utterance_id": {
            "type": "string",
            "title": "Utterance Id"
          },
          "stance": {
            "type": "string",
            "enum": [
              "supports",
              "opposes",
              "evaluates"
            ],
            "title": "Stance"
          }
        },
        "type": "object",
        "required": [
          "claim_text",
          "utterance_id",
          "stance"
        ],
        "title": "SubjectiveClaim"
      },
