# Firecrawl API key for URL scraping (https://www.firecrawl.dev/)
FIRECRAWL_API_KEY=

# OpenAI API key used by DSPy for claim extraction / moderation
# (Google Fact Check Tools API now uses Application Default Credentials — no key needed)
OPENAI_API_KEY=

# Vertex Gemini tiers. Fast handles extraction/classification; Pro is
# reserved for synthesis agents that combine all upstream signals.
VERTEXAI_FAST_MODEL=google-vertex:gemini-3-flash-preview
VERTEXAI_MODEL=google-vertex:gemini-3.1-pro-preview

# App-wide Gemini concurrency cap per process. Production currently runs one
# Vibecheck server instance, so this stays globally authoritative there.
VERTEX_MAX_CONCURRENCY=4

# Supabase project URL (e.g., https://<project-ref>.supabase.co)
VIBECHECK_SUPABASE_URL=

# Supabase Postgres DB password (only needed for direct DB access if used)
VIBECHECK_SUPABASE_DB_PASSWORD=

# Supabase anon (publishable) key used by supabase-py client for cache reads/writes
VIBECHECK_SUPABASE_ANON_KEY=

# Coarse safety-valve rate limit on direct hits to /api/analyze. Per-real-user
# enforcement now lives at the web tier (vibecheck-web reads X-Forwarded-For).
# This bucket keys on the SolidStart server IP, so set high (default 5000).
# If 429s start firing on legit traffic, raise this knob — do NOT lower it.
RATE_LIMIT_PER_IP_PER_HOUR=5000

# How long cached fact-check results stay warm, in hours (default 72)
CACHE_TTL_HOURS=72
