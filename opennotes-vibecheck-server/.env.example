# Firecrawl API key for URL scraping (https://www.firecrawl.dev/)
FIRECRAWL_API_KEY=

# Google Fact Check Tools API key (https://developers.google.com/fact-check/tools/api/)
GOOGLE_FACT_CHECK_API_KEY=

# OpenAI API key used by DSPy for claim extraction / moderation
OPENAI_API_KEY=

# Supabase project URL (e.g., https://<project-ref>.supabase.co)
VIBECHECK_SUPABASE_URL=

# Supabase Postgres DB password (only needed for direct DB access if used)
VIBECHECK_SUPABASE_DB_PASSWORD=

# Supabase anon (publishable) key used by supabase-py client for cache reads/writes
VIBECHECK_SUPABASE_ANON_KEY=

# Max vibecheck requests per IP per hour (default 10)
RATE_LIMIT_PER_IP_PER_HOUR=10

# How long cached fact-check results stay warm, in hours (default 72)
CACHE_TTL_HOURS=72
